chips = {}
for i, item in enumerate(ingredients):
    row, col = divmod(i, 6)
    ch = Chip(grid_f, item, EMOJI.get(item,"🍽"),
              cmd=lambda x=item: add_ingredient(x),
              bg=CARD_BG, w=82, h=60)
    ch.grid(row=row, column=col, padx=4, pady=4)
    chips[item] = ch

# ─────────────────────────────────────────────────────────
# 미니게임 오버레이 (메인 화면 위를 덮는 프레임)
