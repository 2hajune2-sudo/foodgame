# ─── 전체 창 크기 ────────────────────────────────────────
# 하단 쓰레기통 바가 화면/작업표시줄 등에 의해 잘리지 않도록
# 여유 공간을 충분히 두고 전체 높이를 늘림
W, H = 1300, 820

# ─── 헬퍼 ───────────────────────────────────────────────

def rrp(x1, y1, x2, y2, r):
    return [
        x1+r,y1, x2-r,y1, x2,y1, x2,y1+r,
        x2,y2-r, x2,y2, x2-r,y2, x1+r,y2,
        x1,y2, x1,y2-r, x1,y1+r, x1,y1,
    ]


def vgrad(canvas, x1, y1, x2, y2, c1, c2, steps=100):
    r1,g1,b1 = canvas.winfo_rgb(c1)
    r2,g2,b2 = canvas.winfo_rgb(c2)
    h = y2 - y1
    for i in range(steps):
        t = i/steps
        r = int(r1+(r2-r1)*t)>>8
        g = int(g1+(g2-g1)*t)>>8
        b = int(b1+(b2-b1)*t)>>8
        col = f"#{r:02x}{g:02x}{b:02x}"
        canvas.create_rectangle(x1, y1+h*i/steps, x2, y1+h*(i+1)/steps+1, fill=col, outline=col)


def card(canvas, x, y, w, h, r=20, pad=16, bg=CARD_BG, shadow=CARD_SHADOW, sdx=5, sdy=5):
    canvas.create_polygon(rrp(x+sdx,y+sdy,x+w+sdx,y+h+sdy,r), smooth=True, fill=shadow, outline="")
    canvas.create_polygon(rrp(x,y,x+w,y+h,r), smooth=True, fill=bg, outline="")
    f = tk.Frame(canvas, bg=bg)
    canvas.create_window(x+pad, y+pad, anchor="nw", window=f, width=w-2*pad, height=h-2*pad)
    return f


# ─── 커스텀 위젯 ─────────────────────────────────────────

class RBtn(tk.Canvas):
    def __init__(self, parent, text, cmd=None, w=120, h=40, r=14,
                 bg=CARD_BG, fc=PRIMARY, hc=PRIMARY_H, pc=PRIMARY_P,
                 tc="#FFF", font=("맑은 고딕",10,"bold"),
                 dc="#D9D2C5", dtc="#A89C89"):
        super().__init__(parent, width=w, height=h, bg=bg, highlightthickness=0)
        self._cmd=cmd; self.w=w; self.h=h; self.fc=fc; self.hc=hc; self.pc=pc
        self.dc=dc; self.tc=tc; self.dtc=dtc; self.on=True
        self._sh = self.create_polygon(rrp(2,2,w-2,h-2,r), smooth=True, fill=fc, outline="")
        self._tx = self.create_text(w/2,h/2, text=text, fill=tc, font=font, justify="center")
        self.bind("<Enter>",  lambda e: self.on and (self.itemconfig(self._sh,fill=self.hc), self.config(cursor="hand2")))
        self.bind("<Leave>",  lambda e: self.on and self.itemconfig(self._sh,fill=self.fc))
        self.bind("<ButtonPress-1>",   lambda e: self.on and self.itemconfig(self._sh,fill=self.pc))
        self.bind("<ButtonRelease-1>", self._rel)
    def _rel(self, e):
        if not self.on: return
        self.itemconfig(self._sh, fill=self.hc)
        if 0<=e.x<=self.w and 0<=e.y<=self.h and self._cmd: self._cmd()
    def enable(self, v):
        self.on=v
        self.itemconfig(self._sh, fill=self.fc if v else self.dc)
        self.itemconfig(self._tx, fill=self.tc if v else self.dtc)
    def set_text(self, t): self.itemconfig(self._tx, text=t)


class Chip(tk.Canvas):
    def __init__(self, parent, name, emoji, cmd, bg=CARD_BG, w=82, h=60):
        super().__init__(parent, width=w, height=h, bg=bg, highlightthickness=0)
        self._cmd=cmd; self.on=True; self.w=w; self.h=h
        self._sh = self.create_polygon(rrp(2,2,w-2,h-2,16), smooth=True, fill=CHIP_BG, outline=CHIP_BD, width=1)
        self._em = self.create_text(w/2, h/2-10, text=emoji, font=("맑은 고딕",17))
        self._nm = self.create_text(w/2, h/2+14, text=name, font=("맑은 고딕",8,"bold"), fill=TEXT_DARK)
        self.bind("<Enter>",    lambda e: self.on and (self.itemconfig(self._sh,fill=CHIP_H), self.config(cursor="hand2")))
        self.bind("<Leave>",    lambda e: self.on and self.itemconfig(self._sh,fill=CHIP_BG))
        self.bind("<Button-1>", lambda e: self.on and self._cmd and self._cmd())
    def enable(self, v):
        self.on=v
        self.itemconfig(self._sh, fill=CHIP_BG if v else CHIP_DIS, outline=CHIP_BD if v else CHIP_DIS_BD)
        self.itemconfig(self._nm, fill=TEXT_DARK if v else CHIP_DIS_TXT)
        self.config(cursor="hand2" if v else "arrow")


class Slots(tk.Canvas):
    def __init__(self, parent, bg=CARD_BG, n=5, sz=32, gap=8):
        tw = n*sz+(n-1)*gap+16
        super().__init__(parent, width=tw, height=sz+16, bg=bg, highlightthickness=0)
        self.n=n; self._c=[]; self._t=[]
        for i in range(n):
            x1=8+i*(sz+gap); y1=8; x2=x1+sz; y2=y1+sz
            c=self.create_oval(x1,y1,x2,y2, outline=CHIP_BD, width=2, fill=CHIP_BG, dash=(3,2))
            t=self.create_text((x1+x2)/2,(y1+y2)/2, text="", font=("맑은 고딕",16))
            self._c.append(c); self._t.append(t)
    def update(self, sel, em):
        for i in range(self.n):
            if i<len(sel):
                self.itemconfig(self._c[i], fill=CHIP_H, outline=GOLD, dash=())
                self.itemconfig(self._t[i], text=em.get(sel[i],"🍽"))
            else:
                self.itemconfig(self._c[i], fill=CHIP_BG, outline=CHIP_BD, dash=(3,2))
                self.itemconfig(self._t[i], text="")


class Pot(tk.Canvas):
    def __init__(self, parent, bg=CARD_BG, size=120):
        super().__init__(parent, width=size, height=size, bg=bg, highlightthickness=0)
        s=size
        self._sh = self.create_polygon(rrp(4,4,s-4,s-4,26), smooth=True, fill=NEUTRAL_BG, outline=NEUTRAL_BD, width=2)
        self._ic = self.create_text(s/2, s/2-16, text="🍲", font=("맑은 고딕",36))
        self._lb = self.create_text(s/2, s/2+30, text="", font=("맑은 고딕",10,"bold"),
                                     fill=TEXT_DARK, width=s-20, justify="center")
    def default(self):
        self.itemconfig(self._sh, fill=NEUTRAL_BG, outline=NEUTRAL_BD)
        self.itemconfig(self._ic, text="🍲")
        self.itemconfig(self._lb, text="", fill=TEXT_DARK)
    def success(self, dish):
        self.itemconfig(self._sh, fill=SUCCESS_BG, outline=SUCCESS_BD)
        self.itemconfig(self._ic, text="🍲")
        self.itemconfig(self._lb, text=dish, fill=SUCCESS_TXT)
    def fail(self):
        self.itemconfig(self._sh, fill=FAIL_BG, outline=FAIL_BD)
        self.itemconfig(self._ic, text="💨")
        self.itemconfig(self._lb, text="괴식...", fill=FAIL_TXT)


class Badge(tk.Canvas):
    def __init__(self, parent, bg, icon, val, fc, w=130, h=40, tc="#FFF"):
        super().__init__(parent, width=w, height=h, bg=bg, highlightthickness=0)
        self.create_polygon(rrp(2,2,w-2,h-2,h/2), smooth=True, fill=fc, outline="")
        self.create_text(24, h/2, text=icon, font=("맑은 고딕",16))
        self._v = self.create_text(w/2+10, h/2, text=val, font=("맑은 고딕",12,"bold"), fill=tc)
    def set(self, t): self.itemconfig(self._v, text=t)


class PBar(tk.Canvas):
    def __init__(self, parent, bg, w=220, h=14, fc=TEAL, tc="#F1E6D2"):
        super().__init__(parent, width=w, height=h, bg=bg, highlightthickness=0)
        self.w=w; self.h=h; self.fc=fc; self._bar=None
        self.create_polygon(rrp(0,0,w,h,h/2), smooth=True, fill=tc, outline="")
        self.set(0)
    def set(self, ratio):
        ratio=max(0,min(1,ratio))
        if self._bar: self.delete(self._bar); self._bar=None
        bw=self.w*ratio
        if bw>self.h:
            self._bar=self.create_polygon(rrp(0,0,bw,self.h,self.h/2), smooth=True, fill=self.fc, outline="")
        elif bw>0:
            self._bar=self.create_oval(0,0,self.h,self.h, fill=self.fc, outline="")


