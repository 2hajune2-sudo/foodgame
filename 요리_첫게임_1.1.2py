sm_overlay = tk.Frame(root, bg=BG_BOTTOM)

# ─────────────────────────────────────────────────────────
# 함수
# ─────────────────────────────────────────────────────────

def anim_val(setter, s, e, steps=12, delay=16, sfx=""):
    diff = e - s
    def step(i):
        setter(f"{int(round(s+diff*i/steps))}{sfx}")
        if i < steps: root.after(delay, lambda: step(i+1))
    step(0)

def upd_money(old, new): anim_val(money_badge.set, old, new, sfx="원")
def upd_progress():
    n = len(discovered)
    pbar.set(n/TOTAL if TOTAL else 0)
    ptxt.config(text=f"{n}/{TOTAL}")
    recipe_badge.set(f"{n}/{TOTAL}")

def upd_chips():
    full = len(selected) >= 5
    for ch in chips.values(): ch.enable(not full)

def upd_slots(): slots.update(selected, EMOJI)

def set_status(txt, bg=NEUTRAL_BG): status_lbl.config(text=txt, bg=bg)

def update_hint_label():
    hint_lbl.config(text=f"💡 힌트 {hint_count}개 보유")

def add_ingredient(item):
    if len(selected) >= 5: return
    selected.append(item)
    upd_slots(); upd_chips()

def reset_selection():
    selected.clear(); upd_slots(); upd_chips()
    pot.default(); set_status("재료 5개를 골라보세요!")

def best_hint():
    best_d, best_n, best_i = None, -1, []
    ss = set(selected)
    for dish, recipe in recipes.items():
        if dish in discovered: continue
        common = ss & set(recipe)
        if len(common) > best_n:
            best_n, best_d, best_i = len(common), dish, list(common)
    return best_d, best_n, best_i

def cook():
    global money
    if len(selected) != 5:
        set_status("재료를 정확히 5개 선택하세요!", FAIL_BG); return
    cost = len(selected) * COST
    if money < cost:
        set_status(f"돈이 부족합니다!\n{cost}원 필요", FAIL_BG); return

    old = money; money -= cost
    key = frozenset(selected)

    if key in recipe_lookup:
        dish = recipe_lookup[key]
        pot.success(dish)
        if dish in discovered:
            set_status(f"{dish} 완성!\n(이미 발견, 보상 없음)", SUCCESS_BG)
            hist.insert(tk.END, f"✔ {dish} (중복, -{cost}원)\n", "dup")
        else:
            discovered.add(dish); money += REWARD
            set_status(f"🎉 신규 레시피 발견!\n{dish}\n(+{REWARD}원, -{cost}원)", SUCCESS_BG)
            hist.insert(tk.END, f"⭐ {dish} 발견! (+{REWARD}원, -{cost}원)\n", "new")
            upd_progress()
            refresh_setmenu_if_open()
    else:
        hd, hn, hi = best_hint()
        pot.fail()
        if hd is None: set_status(f"실패! (-{cost}원)\n모든 레시피를 발견했어요!", FAIL_BG)
        else:          set_status(f"실패! (-{cost}원)\n힌트: {hd} ({hn}/5)\n{', '.join(hi)}", FAIL_BG)
        hist.insert(tk.END, f"✖ 괴식 (-{cost}원)\n", "fail")

    hist.see(tk.END)
    upd_money(old, money)
    selected.clear(); upd_slots(); upd_chips()

def search_trash():
    global money
    old = money; roll = random.random()
    if   roll < 0.01: money += 5; trash_msg.config(text="🎉 5원을 주웠습니다!", fg=SUCCESS_TXT)
    elif roll < 0.06: money += 1; trash_msg.config(text="동전 1원을 주웠습니다!", fg=TEAL_DARK)
    else:                          trash_msg.config(text="아무것도 없네요...", fg=TEXT_MUTED)
    upd_money(old, money)

def use_hint():
    global hint_count
    if hint_count <= 0:
        set_status("힌트가 없습니다!\n미니게임으로 힌트를 모아보세요.", FAIL_BG)
        return
    hd, hn, hi = best_hint()
    if hd is None:
        set_status("모든 레시피를 이미 발견했어요!", SUCCESS_BG)
        return
    missing = [x for x in recipes[hd] if x not in selected]
    hint_count -= 1
    update_hint_label()
    if not missing:
        set_status(f"'{hd}'의 재료를 이미 모두 골랐어요!\n요리하기를 눌러보세요.", SUCCESS_BG)
    else:
        reveal = random.choice(missing)
        set_status(f"💡 힌트!\n가장 가까운 레시피에는\n'{reveal}' 재료가 필요해요!", NEUTRAL_BG)

# ── 미니게임 ─────────────────────────────────────────────

def start_minigame():
    global money
    if money < 1:
        set_status("돈이 부족해서 미니게임을 할 수 없어요!", FAIL_BG)
        return
    old = money
    money -= 1
    upd_money(old, money)
    set_status("🎮 미니게임 입장! (-1원)", NEUTRAL_BG)
    open_minigame()

def open_minigame():
    for w in mg_overlay.winfo_children():
        w.destroy()
    mg_overlay.place(x=0, y=0, width=W, height=H)

    mc = tk.Canvas(mg_overlay, width=W, height=H, highlightthickness=0, bg=BG_BOTTOM)
    mc.pack(fill="both", expand=True)
    vgrad(mc, 0, 0, W, H, BG_TOP, BG_BOTTOM)

    cx, cy = W/2, H/2
    pan_r = 140

    # 음식 결정: 계란후라이 80%, 스테이크 20%
    food = "스테이크" if random.random() < 0.2 else "계란후라이"
    food_emoji = "🥩" if food == "스테이크" else "🍳"

    mc.create_text(cx, cy-pan_r-110, text="순발력 게임  (입장료 -1원)", font=("맑은 고딕",22,"bold"), fill=TEXT_DARK)
    mc.create_text(cx, cy-pan_r-78, text="'클릭!!!' 글자가 나오면 최대한 빠르게 클릭하세요!",
                    font=("맑은 고딕",11), fill=TEXT_MUTED)

    # 프라이팬
    mc.create_oval(cx-pan_r, cy-pan_r, cx+pan_r, cy+pan_r, fill="#3A3A3A", outline="#1F1F1F", width=6)
    mc.create_oval(cx-pan_r+14, cy-pan_r+14, cx+pan_r-14, cy+pan_r-14, fill="#5A5A5A", outline="")
    mc.create_rectangle(cx+pan_r-12, cy-14, cx+pan_r+170, cy+14, fill="#3A3A3A", outline="")
    mc.create_text(cx, cy, text=food_emoji, font=("맑은 고딕",78))

    count_id = mc.create_text(cx, cy-pan_r-30, text="3", font=("맑은 고딕",40,"bold"), fill=PRIMARY)
    result_id = mc.create_text(cx, cy+pan_r+55, text="", font=("맑은 고딕",26,"bold"), fill=TEXT_DARK)

    state = {"clicked": False, "show_time": None}

    def resolve(elapsed):
        if state["clicked"]:
            return
        state["clicked"] = True
        mc.unbind("<Button-1>")
        if elapsed is None or elapsed > 0.5:
            result = "실패"
        elif elapsed <= 0.3:
            result = "대성공"
        else:
            result = "성공"
        apply_minigame_result(result, food)
        mc.itemconfig(result_id, text=f"{result}!",
                       fill=(SUCCESS_TXT if result != "실패" else FAIL_TXT))
        root.after(1100, close_minigame)

    def on_click(event=None):
        if state["clicked"]:
            return
        if state["show_time"] is None:
            resolve(None)   # 너무 일찍 클릭 -> 실패
        else:
            resolve(time.time() - state["show_time"])

    def show_click_prompt():
        if state["clicked"]:
            return
        mc.itemconfig(count_id, text="")
        size = int(pan_r * 2 * 1.15)
        mc.create_text(cx, cy, text="클릭!!!", font=("맑은 고딕", max(20, size//5), "bold"),
                        fill="#FF2D2D")
        state["show_time"] = time.time()
        # 일정 시간 안에 클릭하지 않으면 자동 실패 처리
        root.after(900, lambda: resolve(999))

    def countdown(n):
        if state["clicked"]:
            return
        if n <= 0:
            mc.itemconfig(count_id, text="")
            delay_ms = int(random.uniform(2, 5) * 1000)
            root.after(delay_ms, show_click_prompt)
            return
        mc.itemconfig(count_id, text=str(n))
        root.after(1000, lambda: countdown(n-1))

    mc.bind("<Button-1>", on_click)
    countdown(3)

def apply_minigame_result(result, food):
    global hint_count
    if result == "실패":
        return
    gain = 1 if result == "성공" else 2
    if food == "스테이크":
        gain *= 2
    hint_count += gain
    update_hint_label()

def close_minigame():
    mg_overlay.place_forget()

# ── 세트 메뉴 ─────────────────────────────────────────────

def open_setmenu():
    for w in sm_overlay.winfo_children():
        w.destroy()
    sm_overlay.place(x=0, y=0, width=W, height=H)
    _build_setmenu_ui()

def _build_setmenu_ui():
    sm_cv = tk.Canvas(sm_overlay, width=W, height=H, highlightthickness=0, bg=BG_BOTTOM)
    sm_cv.pack(fill="both", expand=True)
    vgrad(sm_cv, 0, 0, W, H, BG_TOP, BG_BOTTOM)

    # 제목
    sm_cv.create_text(W/2, 38, text="🍱 세트 메뉴",
                       font=("맑은 고딕", 22, "bold"), fill=TEXT_DARK)
    sm_cv.create_text(W/2, 62, text="세트를 완성하면 힌트 5개 + 100원을 받을 수 있어요!",
                       font=("맑은 고딕", 10), fill=TEXT_MUTED)

    # ← 돌아가기 버튼
    back_f = card(sm_cv, 20, 14, 120, 46, r=14, pad=7)
    back_btn = RBtn(back_f, "← 돌아가기", w=106, h=32, r=12,
                    bg=CARD_BG, fc=SECONDARY, hc=SECONDARY_H, pc=SECONDARY_P,
                    font=("맑은 고딕", 9, "bold"))
    back_btn._cmd = close_setmenu
    back_btn.pack()

    # 카드 레이아웃 : 2열 × 5행
    COLS    = 2
    CW      = 612   # 카드 너비
    CH      = 116   # 카드 높이
    X_OFF   = [18, 656]
    Y_START = 78
    Y_GAP   = 126   # 행 간격

    for idx, (set_name, dishes) in enumerate(SET_MENUS.items()):
        col = idx % COLS
        row = idx // COLS
        cx  = X_OFF[col]
        cy  = Y_START + row * Y_GAP

        found    = [d for d in dishes if d in discovered]
        n_found  = len(found)
        complete = n_found == len(dishes)
        claimed  = set_name in set_rewards

        if claimed:
            bg_c = SUCCESS_BG
        elif complete:
            bg_c = "#FFF8DC"   # 완성 미수령 - 연한 노란색
        else:
            bg_c = CARD_BG

        f = card(sm_cv, cx, cy, CW, CH, r=18, pad=12, bg=bg_c)

        # 첫 줄: 세트 이름 + 진행도
        row1 = tk.Frame(f, bg=bg_c)
        row1.pack(fill="x")
        tk.Label(row1, text=set_name, font=("맑은 고딕", 12, "bold"),
                 bg=bg_c, fg=TEXT_DARK).pack(side="left")
        prog_fg = SUCCESS_TXT if complete else (PRIMARY if n_found > 0 else TEXT_MUTED)
        tk.Label(row1, text=f"{n_found} / {len(dishes)}",
                 font=("맑은 고딕", 10, "bold"), bg=bg_c, fg=prog_fg).pack(side="right")

        # 두 번째 줄: 요리 슬롯들
        row2 = tk.Frame(f, bg=bg_c)
        row2.pack(fill="x", pady=(6, 0))

        for dish in dishes:
            if dish in discovered:
                s_bg = SUCCESS_BG; s_fg = SUCCESS_TXT; s_txt = dish
            else:
                s_bg = CHIP_DIS;   s_fg = CHIP_DIS_TXT; s_txt = "?"
            slot = tk.Frame(row2, bg=s_bg, highlightbackground=CHIP_BD,
                            highlightthickness=1)
            slot.pack(side="left", padx=2)
            tk.Label(slot, text=s_txt, font=("맑은 고딕", 9),
                     bg=s_bg, fg=s_fg, padx=5, pady=3).pack()

        # 보상 버튼 또는 완료 표시
        if complete and not claimed:
            def _claim(sn=set_name):
                claim_set_reward(sn)
                open_setmenu()   # 화면 갱신
            rw_btn = RBtn(row2, "🎁 보상받기", w=108, h=28, r=12,
                          bg=bg_c, fc=PRIMARY, hc=PRIMARY_H, pc=PRIMARY_P,
                          font=("맑은 고딕", 9, "bold"))
            rw_btn._cmd = _claim
            rw_btn.pack(side="right", padx=(6, 0))
        elif claimed:
            tk.Label(row2, text="✅ 완료", font=("맑은 고딕", 10, "bold"),
                     bg=bg_c, fg=SUCCESS_TXT).pack(side="right", padx=(6, 0))

def close_setmenu():
    sm_overlay.place_forget()

def claim_set_reward(set_name):
    global money, hint_count
    if set_name in set_rewards:
        return
    set_rewards.add(set_name)
    old = money
    money  += 100
    hint_count += 5
    upd_money(old, money)
    update_hint_label()
    hist.insert(tk.END, f"🍱 {set_name} 완성! (+100원, +힌트5)\n", "new")
    hist.see(tk.END)

def refresh_setmenu_if_open():
    try:
        if sm_overlay.winfo_ismapped():
            open_setmenu()
    except Exception:
        pass

# 버튼 커맨드 연결
cook_btn._cmd  = cook
reset_btn._cmd = reset_selection
trash_btn._cmd = search_trash
mg_btn._cmd    = start_minigame
hint_btn._cmd  = use_hint
sm_btn._cmd    = open_setmenu

# ─── 초기 상태 ───────────────────────────────────────────
upd_progress(); upd_slots(); upd_chips(); pot.default(); update_hint_label()
hist.insert(tk.END, "🍳 요리를 시작해보세요!\n", "dup")

root.mainloop()
